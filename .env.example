PORT=4000

# Frontend (market-quotes-frontend/.env) — lasciare vuoto se usi il proxy Vite in dev
# VITE_API_BASE=http://localhost:4000

# Netlify — deploy unico (netlify.toml): API su /api via Functions, NON impostare VITE_API_BASE.
# Variabili da aggiungere nel pannello Netlify (Build & deploy → Environment):
# STOOQ_API_KEY=  FCSALE_API_KEY=  STOCK_API_KEY=  METALS_API_KEY=

# Smoke test produzione: npm run smoke:prod

# Opzionale — migliora lo storico giornaliero (gratis su https://stooq.com/q/d/?s=aapl.us&get_apikey)
# STOOQ_API_KEY=

# Opzionale — storico metalli se Yahoo è in pausa (piano free: ~3 req/min)
# FCSALE_API_KEY=

# Opzionale — Alpha Vantage: fallback per azioni, metalli, forex e crypto
# (piano free: ~25 req/giorno). Le due chiavi sono intercambiabili.
# STOCK_API_KEY=
# METALS_API_KEY=

# Opzionale — CoinGecko: fallback crypto gratuito (funziona anche senza chiave).
# Con una demo key aumentano i rate limit (https://www.coingecko.com/en/api).
# COINGECKO_API_KEY=

# Circuit breaker fonti dati (opzionale): dopo N fallimenti sistemici consecutivi
# un provider viene saltato per il cooldown, poi ritentato (half-open).
# Stato live: GET /api/health/providers
# CB_FAILURE_THRESHOLD=3
# CB_COOLDOWN_MS=30000

# Portfolio (NeonDB PostgreSQL serverless)
# DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
# JWT_SECRET=genera-una-chiave-lunga-e-casuale
# CORS_ORIGIN=https://tuodominio.netlify.app,http://localhost:5173
# APP_BASE_URL=https://tuodominio.netlify.app
# CRON_SECRET=chiave-per-trigger-cron-manuale

# Notifiche Telegram (@BotFather → TELEGRAM_BOT_TOKEN)
# TELEGRAM_BOT_TOKEN=

# WhatsApp — Twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# WhatsApp — Meta Cloud API (alternativa)
# WHATSAPP_CLOUD_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Slack — nessuna config server: l'utente incolla il proprio Incoming Webhook
# in Notifiche (https://hooks.slack.com/services/…).

# Email alert — provider HTTP (nessun SMTP). Basta configurare UN provider.
# Il destinatario è l'email dell'account; l'utente attiva l'opt-in in Notifiche.
# EMAIL_FROM="Market Monitor <alert@tuo-dominio.it>"
# Resend (consigliato)
# RESEND_API_KEY=
# Brevo / Sendinblue (alternativa)
# BREVO_API_KEY=

# Web Push (PWA) — genera le chiavi con: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:alerts@tuo-dominio.it
# Frontend (opzionale): la public key è servita da /api/notifications/push/publicKey,
# oppure impostala in market-quotes-frontend/.env come VITE_VAPID_PUBLIC_KEY=

# Assistente AI (opzionale) — abilita risposte libere e "umane" dell'assistente.
# Senza chiave l'assistente funziona in modalità base (spiegazioni indicatori,
# apertura analisi/previsioni, watchlist/portfolio dal contesto).
#
# RapidAPI — chat LLM (risposte libere dell'assistente). Priorità su OpenAI.
# Risponde nella lingua scelta nel widget. Abilita la modalità "risposte libere":
# senza chiave l'assistente resta in modalità base (solo intent/azioni locali).
# RAPIDAPI_KEY=la-tua-rapidapi-key
# ChatGPT-42 (consigliato): host + path del proprio piano.
# RAPIDAPI_CHAT_HOST=chatgpt-42.p.rapidapi.com
# RAPIDAPI_CHAT_PATH=/conversationgpt4-2
# In alternativa endpoint più veloce: RAPIDAPI_CHAT_PATH=/gpt4
# Oppure LLaMA 3.3 (OpenAI-compatibile):
# RAPIDAPI_CHAT_HOST=llama-3-3-70b-instruct-multilingual-chat-ai-by-meta.p.rapidapi.com
# RAPIDAPI_CHAT_PATH=/chat/completions
# NOTA: se il piano RapidAPI esaurisce la quota (HTTP 429) l'assistente ricade
# automaticamente sulla risposta locale mostrando una nota; imposta un fallback
# OpenAI qui sotto per continuità delle risposte libere.
#
# RapidAPI — Text-to-Speech (voce umana/neurale). Usa la stessa RAPIDAPI_KEY.
# Imposta host/path della tua sottoscrizione TTS su RapidAPI; se assenti,
# l'assistente usa la voce del browser (Web Speech).
# Esempio funzionante: Streamlined Edge TTS (voci neurali Microsoft, GET).
# Il backend mappa il locale (it-IT, en-US, ...) alla voce neurale corretta.
# RAPIDAPI_TTS_HOST=streamlined-edge-tts.p.rapidapi.com
# RAPIDAPI_TTS_PATH=/tts
# RAPIDAPI_TTS_METHOD=GET
# RAPIDAPI_TTS_TEXT_FIELD=text
# RAPIDAPI_TTS_VOICE_FIELD=voice
# RAPIDAPI_TTS_VOICE=it-IT-ElsaNeural
# Per altre API TTS adatta METHOD (POST/GET) e i nomi dei campi
# (text/input/msg, voice/voice_id/lang).
#
# RapidAPI — Traduttore (assistente multilingue). Usa la stessa RAPIDAPI_KEY.
# Esempio: Advanced Multilanguage AI Translator API With Fast Responses.
# RAPIDAPI_TRANSLATE_HOST=advanced-multilanguage-ai-translator-api-with-fast-responses.p.rapidapi.com
# RAPIDAPI_TRANSLATE_PATH=/translate.php
#
# OpenAI (fallback opzionale)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# JWT refresh + access token
# JWT_ACCESS_EXPIRES=15m
# JWT_REFRESH_EXPIRES=7d

# ── Auth0 (opzionale — sostituisce login email/password portfolio) ───
# Dashboard: Application SPA + API con audience. Callback: http://localhost:5173/callback
# Abilita MFA in Security → Multi-factor Auth; Action Post-Login per forzare MFA su Portfolio.
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=          # solo se serve M2M lato server
# AUTH0_AUDIENCE=https://api.marketmonitor.app
# AUTH0_MFA_ENABLED=true
# VITE_AUTH0_DOMAIN=your-tenant.auth0.com
# VITE_AUTH0_CLIENT_ID=
# VITE_AUTH0_AUDIENCE=https://api.marketmonitor.app
# VITE_AUTH0_MFA_ENABLED=true

# ── Web Push PWA (VAPID) ─────────────────────────────────────────────
# Genera: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@marketmonitor.app
# VITE_VAPID_PUBLIC_KEY=        # stessa chiave pubblica (opzionale, altrimenti da /api/.../publicKey)
# VITE_ENABLE_SW_DEV=1          # registra SW in dev per test push locali

# Redis cache distribuito (opzionale — npm install ioredis)
# REDIS_URL=redis://localhost:6379

# OAuth social login
# OAuth portfolio (Netlify → Site settings → Environment variables)
# GOOGLE_CLIENT_ID=              # Google Cloud OAuth client (Web)
# VITE_GOOGLE_CLIENT_ID=         # stesso valore se serve al build Vite
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# VITE_GITHUB_CLIENT_ID=
# APPLE_CLIENT_ID=
# VITE_APPLE_CLIENT_ID=

# WebAuthn passkey (opzionale — npm install @simplewebauthn/server)
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:5173
# WEBAUTHN_RP_NAME=Market Monitor

# Observability (opzionale)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# DATADOG_API_KEY=
# LOG_LEVEL=info

# Cron locale (opzionale, dev): ENABLE_PORTFOLIO_CRON=true

# ── Robustezza server (dev / produzione) ─────────────────────────────
# Concorrenza massima fetch mercato (default 3)
# MAX_MARKET_LOADS=3
# MARKET_QUEUE_MAX=24
# MARKET_QUEUE_TIMEOUT_MS=15000
# MARKET_LOAD_TIMEOUT_MS=14000
# MARKET_BATCH_CONCURRENCY=3
# REQUEST_TIMEOUT_MS=25000
# HISTORY_BATCH_TIMEOUT_MS=10000
# Redis hydrate timeout ms (evita blocchi se Redis lento)
# REDIS_HYDRATE_TIMEOUT_MS=800
# Bridge WS prezzi live (disabilitato in dev di default)
# ENABLE_WS_BRIDGE=true
# Fallback curl verso Yahoo (sconsigliato: satura CPU)
# YAHOO_ALLOW_CURL=0

# ── Rate limiting tier-based (opzionale) ─────────────────────────────
# Limiti per finestra temporale, distinti per tier. Header standard su ogni
# risposta: RateLimit-Limit / RateLimit-Remaining / RateLimit-Reset (+ Retry-After).
# Tier: anonymous (per IP) · free (JWT valido) · pro (allowlist o claim tier:'pro').
# Gli endpoint onerosi pesano di più (chat=5, forecast=4, intelligence=3…).
# RL_WINDOW_MS=60000
# RL_ANON_MAX=120
# RL_FREE_MAX=400
# RL_PRO_MAX=1200
# RL_PRO_USER_IDS=            # id utente (virgola-separati) trattati come pro
# RL_DISABLED=1               # disattiva il rate limiting (debug)

# Migrazione schema: npm run db:migrate
